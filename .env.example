# -- App ------------------------------------------
NODE_ENV=development
PORT=3000
APP_NAME=palki-platform
APP_VERSION=0.0.1

# -- Kafka ----------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=palki-gateway
KAFKA_CONSUMER_GROUP=palki-gateway-group
KAFKA_SSL=false

# -- Redis ----------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# -- Database -------------------------------------
DATABASE_URL=postgresql://palki:palki_dev@localhost:5432/palki
DATABASE_SSL=false
DATABASE_POOL_SIZE=10

# -- Auth -----------------------------------------
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=604800
BCRYPT_ROUNDS=12

# -- Security -------------------------------------
MESSAGE_SIGNING_SECRET=change-me-to-64-byte-random-secret
REFRESH_TOKEN_SECRET=change-me-to-32-byte-random-secret
OTP_ENCRYPTION_KEY=change-me-to-32-byte-random-secret

# -- Logging --------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty
